# ═══════════════════════════════════════════════════════════════
#  Supply Chain Risk Dashboard — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ───────────────────────────────────────────────────

# OpenAI API key — powers AI risk summaries and holistic assessments
# Get one at: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (cheap, ~$0.15 per 1M input tokens)
OPENAI_API_KEY=sk-your-openai-key

# FRED API key — Federal Reserve Economic Data
# Powers: commodity prices (wheat, corn, oats, peanuts, packaging) + economic indicators
# Get one (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# EIA API key — Energy Information Administration
# Powers: retail gasoline + diesel prices by region
# Get one (free): https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key

# Mapbox access token — powers the interactive risk map
# Get one (free, 50K loads/mo): https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your-mapbox-token

# ── OPTIONAL ───────────────────────────────────────────────────

# NewsAPI key — additional news sources (GDELT is used as the primary source)
# Get one (free tier): https://newsapi.org/register
NEWSAPI_KEY=

# Allowed CORS origins — comma-separated list. If unset, all origins allowed.
# Example: https://dashboard.example.com,http://localhost:5173
ALLOWED_ORIGINS=

# ── INFRASTRUCTURE ─────────────────────────────────────────────

# Port the dashboard listens on (default: 9049)
PORT=9049

# NODE_ENV — 'production' in Docker, 'development' locally
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════
# Data sources that require NO API key:
#   - NWS (weather alerts)      https://www.weather.gov
#   - Open-Meteo (forecasts)    https://open-meteo.com
#   - GDELT (news)              https://www.gdeltproject.org
#   - Frankfurter (FX rates)    https://www.frankfurter.app
# ═══════════════════════════════════════════════════════════════
